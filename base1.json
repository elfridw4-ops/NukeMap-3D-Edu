{
  "project": {
    "name": "NukeMap 3D (Edu)",
    "objective": "Visualiser l'impact potentiel d'explosions nucléaires historiques ou théoriques et simuler les échelles de destruction via des outils d'information cartographiques et balistiques publics afin d'éduquer et de sensibiliser.",
    "target_users": [
      "Professeurs d'histoire",
      "Chercheurs en géopolitique",
      "Étudiants",
      "Grand public curieux de physique"
    ],
    "main_features": [
      "Simulation sur carte avec rayons évalués selon des modèles mathématiques reconnus",
      "Sélection d'arsenal",
      "Simulation d'airburst et surface burst (futur)"
    ]
  },
  "selection_criteria": "Villes historiquement liées au nucléaire, villes côtières stratégiques majeures, et cibles représentatives couvrant différentes géographies.",
